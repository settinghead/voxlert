{
  "name": "@settinghead/voiceforge",
  "version": "0.3.0",
  "description": "LLM-generated voice notifications for Claude Code, Cursor, and OpenClaw, spoken by game characters like the StarCraft Adjutant, Kerrigan, C&C EVA, SHODAN, and more.",
  "type": "module",
  "bin": {
    "voiceforge": "src/cli.js"
  },
  "files": [
    "src/",
    "packs/*/pack.json",
    "packs/*/voice.wav",
    "skills/",
    "assets/*.png",
    "assets/*.jpg",
    "assets/*.gif",
    "config.default.json",
    "voiceforge.sh",
    "openclaw-plugin/",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/voiceforge.js",
    "postinstall": "node src/postinstall.js"
  },
  "license": "MIT",
  "dependencies": {
    "@inquirer/checkbox": "^5.0.0",
    "@inquirer/confirm": "^5.1.0",
    "@inquirer/input": "^4.1.0",
    "@inquirer/select": "^5.1.0",
    "node-notifier": "^10.0.1"
  }
}
